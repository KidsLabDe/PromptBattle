# ── Server ──────────────────────────────────────────────
PB_HOST=0.0.0.0
PB_PORT=8000

# ── Speicherort für Spielverlauf ────────────────────────
# Ordner in dem Bilder + Metadaten pro Spiel gespeichert werden
#PB_HISTORY_DIR=./generated_history

# ── Bildgenerierungs-Backend ───────────────────────────
# "local" = lokales Modell mit GPU (Standard)
# "gemini" = Google Gemini API (keine GPU nötig!)
PB_IMAGE_BACKEND=local

# ── Google Gemini API (wenn PB_IMAGE_BACKEND=gemini) ──
# API Key von https://aistudio.google.com/apikey
PB_GEMINI_API_KEY=
# Verfügbare Modelle:
#   gemini-2.5-flash-image-preview  – schnell, 500 Bilder/Tag gratis
#   gemini-3.1-flash-image-preview  – neuer, schnell
#   imagen-4-fast                   – dediziert, $0.02/Bild
#   imagen-4                        – beste Qualität, $0.04/Bild
PB_GEMINI_MODEL=gemini-2.5-flash-image-preview

# ── Lokales Modell (wenn PB_IMAGE_BACKEND=local) ──────
# FLUX.1-schnell – Standard, braucht ~12 GB VRAM (RTX 3080+)
#PB_FLUX_MODEL=black-forest-labs/FLUX.1-schnell
#PB_FLUX_STEPS=4
#PB_FLUX_GUIDANCE_SCALE=0.0
#PB_FLUX_WIDTH=1024
#PB_FLUX_HEIGHT=1024

# Stable Diffusion XL Turbo – schnell, ~8 GB VRAM (GTX 1080+)
#PB_FLUX_MODEL=stabilityai/sdxl-turbo
#PB_FLUX_STEPS=4
#PB_FLUX_GUIDANCE_SCALE=0.0
#PB_FLUX_WIDTH=512
#PB_FLUX_HEIGHT=512

# Stable Diffusion 1.5 – Klassiker, ~4 GB VRAM (jede GPU)
#PB_FLUX_MODEL=stable-diffusion-v1-5/stable-diffusion-v1-5
#PB_FLUX_STEPS=20
#PB_FLUX_GUIDANCE_SCALE=7.5
#PB_FLUX_WIDTH=512
#PB_FLUX_HEIGHT=512

# Stable Diffusion 2.1 – Gute Qualität, ~6 GB VRAM
#PB_FLUX_MODEL=stabilityai/stable-diffusion-2-1
#PB_FLUX_STEPS=25
#PB_FLUX_GUIDANCE_SCALE=7.5
#PB_FLUX_WIDTH=768
#PB_FLUX_HEIGHT=768

# Empfehlung für GTX 1080 (8 GB):
PB_FLUX_MODEL=stabilityai/sdxl-turbo
PB_FLUX_STEPS=4
PB_FLUX_GUIDANCE_SCALE=0.0
PB_FLUX_WIDTH=512
PB_FLUX_HEIGHT=512

# ── Prompt-Einstellungen ───────────────────────────────
# Prefix der vor jeden Spieler-Prompt gesetzt wird.
PB_PROMPT_PREFIX=

# ── Bildvergleich (CLIP) ──────────────────────────────
PB_CLIP_MODEL=openai/clip-vit-large-patch14
PB_CLIP_RAW_MIN=0.4
PB_CLIP_RAW_MAX=0.9

# ── Display-Passwortschutz ────────────────────────────
# Wenn gesetzt, muss das Passwort beim Start der Beamer-Ansicht eingegeben werden.
# Kann auch per URL-Parameter übergeben werden: http://host/?pw=PASSWORT
#PB_DISPLAY_PASSWORD=

# ── Spieleinstellungen ─────────────────────────────────
PB_ROUND_TIME_SECONDS=60
PB_BASE_THRESHOLD=25
PB_THRESHOLD_STEP=5
PB_MAX_THRESHOLD=75

# ── Telegram Bot ──────────────────────────────────────
# Bot-Token von @BotFather, Chat-ID des Ziel-Chats/Kanals
# Wenn gesetzt, werden Rundenergebnisse + Bilder automatisch gepostet
#PB_TELEGRAM_BOT_TOKEN=
#PB_TELEGRAM_CHAT_ID=

# ── Mehrspieler (Kiosk-Modus) ─────────────────────────
# Sekunden, die das Ergebnis angezeigt wird, bevor die nächste Runde startet
PB_MULTI_RESULT_DISPLAY_SECONDS=10
# Sekunden Pause bevor ein neues Spiel startet (wenn niemand promptet)
PB_MULTI_RESTART_DELAY_SECONDS=5
